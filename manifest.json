{
  "manifest_version": 3,
  "name": "docslatex",
  "version": "1.0.0",
  "description": "Native LaTeX compiling in Google Docs.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "docslatex"
  },
  "icons": {
    "16": "assets/logo.png",
    "32": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["src/highlighter.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["src/compiler.js", "src/decompiler.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/logo.png"],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
